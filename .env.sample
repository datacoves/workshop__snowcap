# Snowflake connection used by plan.sh / apply.sh (mapped to TF_VAR_* for the
# Terraform provider). Copy to .env and fill in. .env is git-ignored.

SNOWFLAKE_ACCOUNT=                                   # Account identifier, e.g. MYORG-MYACCOUNT
SNOWFLAKE_USER=                                      # Service account / user name

# Role used to apply. Terraform here creates databases, warehouses, roles, users
# and grants, so it needs the matching account privileges -- ACCOUNTADMIN is the
# simplest choice for the workshop.
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Key-pair (JWT) auth
SNOWFLAKE_PRIVATE_KEY_PATH=/config/.ssl/dev-private.pem
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
